# ── Telegram ──────────────────────────────────────────────────────────────────
# Token gerado pelo @BotFather
TELEGRAM_BOT_TOKEN=seu_token_aqui

# ID do grupo onde o bot vai postar (negativo para grupos, ex: -1001234567890)
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# ── Concurso ──────────────────────────────────────────────────────────────────
# Data alvo no formato YYYY-MM-DD
TARGET_DATE=2026-05-29

# Número de músicas esperadas
TOTAL_SONGS=6

# ── Monitoramento ─────────────────────────────────────────────────────────────
CHECK_INTERVAL_SECONDS=2
RSS_URL=https://hugogloss.uol.com.br/feed/
HOMEPAGE_URL=https://hugogloss.uol.com.br/
